    "frontends": [
        {"lang": "C++",        "dir": "frontends/cpp/",        "features": "lexer, parser, sema, lowering, constexpr"},
        {"lang": "Python",     "dir": "frontends/python/",     "features": "lexer, parser, sema, lowering"},
        {"lang": "Rust",       "dir": "frontends/rust/",       "features": "lexer, parser, sema, lowering, cargo metadata + crate loader"},
        {"lang": "Java",       "dir": "frontends/java/",       "features": "lexer, parser, sema, lowering — Java 8/17/21/23"},
        {"lang": "C# (.NET)",  "dir": "frontends/dotnet/",     "features": "lexer, parser, sema, lowering — .NET 6/7/8/9"},
        {"lang": "Go",         "dir": "frontends/go/",         "features": "lexer, parser, sema, lowering — go.mod + GOROOT/GOPATH resolver"},
        {"lang": "JavaScript", "dir": "frontends/javascript/", "features": "lexer, parser, sema, lowering — Node.js resolver, .d.ts/.js/.mjs"},
        {"lang": "Ruby",       "dir": "frontends/ruby/",       "features": "lexer, parser, sema, lowering — require/require_relative/load/autoload"},
        {"lang": ".ploy",      "dir": "frontends/ploy/",       "features": "lexer, parser, sema, lowering — orchestration language"}
    ],

    "backends": [
        {"arch": "x86_64",      "dir": "backends/x86_64/", "features": "isel, regalloc, asm_printer, scheduler"},
        {"arch": "ARM64",       "dir": "backends/arm64/",   "features": "isel, regalloc, asm_printer"},
        {"arch": "WebAssembly", "dir": "backends/wasm/",    "features": "wasm_target"}
    ],

    "tools": [
        {"name": "polyc",     "purpose": "Compiler Driver: Source → IR → Target code"},
        {"name": "polyld",    "purpose": "Linker: Object file linking + cross-language glue"},
        {"name": "polyasm",   "purpose": "Assembler: Assembly → Object file"},
        {"name": "polyopt",   "purpose": "Optimiser: IR optimisation passes"},
        {"name": "polyrt",    "purpose": "Runtime Tool: GC / FFI / Thread management"},
        {"name": "polybench", "purpose": "Benchmark: Performance evaluation suite"},
        {"name": "polytopo",  "purpose": "Topology Tool: Inspect/visualise cross-language topology"},
        {"name": "polyui",    "purpose": "IDE: Qt-based desktop IDE"}
    ],

    "dependencies": [
        {"name": "fmt",            "url": "https://github.com/fmtlib/fmt",               "purpose": "Formatted output (>= 11.2.0 required for Apple Clang 21)"},
        {"name": "nlohmann/json",  "url": "https://github.com/nlohmann/json",            "purpose": "JSON processing"},
        {"name": "Catch2",         "url": "https://github.com/catchorg/Catch2",          "purpose": "Unit testing framework"},
        {"name": "mimalloc",       "url": "https://github.com/microsoft/mimalloc",       "purpose": "High-performance memory allocator (mi_* APIs only; global malloc override disabled to keep allocator consistent across dylib boundaries)"},
        {"name": "Qt 6",           "url": "https://www.qt.io/",                          "purpose": "Desktop IDE (polyui)"}
    ],

    "docs_structure": {
        "api":         "API reference (bilingual)",
        "specs":       "Language & IR specifications, optimisation pipeline, runtime ABI, plugin specification, namespace architecture, release packaging",
        "realization": "Implementation details (bilingual; ploy spec, cross-language linking, complex types, package mgmt/import, mixed compilation, class instantiation, compilation model, external packages, per-language runtime, JS/Ruby/Go frontends, editor expansion, topology tool)",
        "tutorial":    "Tutorials: ploy language + project (bilingual)"
    }
