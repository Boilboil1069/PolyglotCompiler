{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-compiler.org/schemas/settings_schema.json",
  "title": "PolyglotCompiler IDE Settings",
  "description": "Schema for settings.json (user / workspace / default).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "editor.fontFamily":         { "type": "string",  "default": "Consolas, Menlo, monospace", "description": "Editor font family.", "descriptionZh": "编辑器字体族。" },
    "editor.fontSize":           { "type": "integer", "default": 11, "minimum": 6, "maximum": 72, "description": "Editor font point size.", "descriptionZh": "编辑器字号。" },
    "editor.tabSize":            { "type": "integer", "default": 4, "minimum": 1, "maximum": 16, "description": "Number of spaces per tab.", "descriptionZh": "Tab 对应的空格数。" },
    "editor.insertSpaces":       { "type": "boolean", "default": true, "description": "Insert spaces when pressing Tab.", "descriptionZh": "按 Tab 时插入空格。" },
    "editor.wordWrap":           { "type": "boolean", "default": false, "description": "Wrap long lines.", "descriptionZh": "自动换行。" },
    "editor.minimap.enabled":    { "type": "boolean", "default": false, "description": "Show minimap.", "descriptionZh": "显示代码缩略图。" },
    "editor.lineNumbers":        { "type": "boolean", "default": true, "description": "Show line numbers.", "descriptionZh": "显示行号。" },
    "editor.renderWhitespace":   { "type": "string",  "enum": ["none","boundary","selection","all"], "default": "selection", "description": "Whitespace rendering mode.", "descriptionZh": "空白字符渲染模式。" },
    "editor.formatOnSave":       { "type": "boolean", "default": false, "description": "Format file on save.", "descriptionZh": "保存时格式化。" },
    "editor.autoSave":           { "type": "string",  "enum": ["off","afterDelay","onFocusChange","onWindowChange"], "default": "off", "description": "Auto-save mode.", "descriptionZh": "自动保存模式。" },
    "editor.autoSaveDelay":      { "type": "integer", "default": 1000, "minimum": 100, "description": "Auto-save delay in ms.", "descriptionZh": "自动保存延迟（毫秒）。" },
    "editor.rulers":             { "type": "array",   "items": { "type": "integer" }, "default": [], "description": "Vertical ruler columns.", "descriptionZh": "垂直标尺列号。" },
    "editor.highlightCurrentLine": { "type": "boolean", "default": true, "description": "Highlight the current line.", "descriptionZh": "高亮当前行。" },
    "editor.bracketMatching":    { "type": "boolean", "default": true, "description": "Highlight matching bracket.", "descriptionZh": "高亮匹配括号。" },
    "editor.autoIndent":         { "type": "boolean", "default": true, "description": "Auto-indent on new line.", "descriptionZh": "自动缩进。" },

    "workbench.colorTheme":      { "type": "string",  "default": "Polyglot Dark", "description": "Active color theme id.", "descriptionZh": "当前颜色主题 id。" },
    "workbench.iconTheme":       { "type": "string",  "default": "default", "description": "Active icon theme id.", "descriptionZh": "当前图标主题 id。" },
    "workbench.startupEditor":   { "type": "string",  "enum": ["welcomePage","newUntitledFile","none"], "default": "welcomePage", "description": "Editor shown at startup.", "descriptionZh": "启动时显示的编辑器。" },
    "workbench.showToolbar":     { "type": "boolean", "default": true, "description": "Show the main toolbar.", "descriptionZh": "显示主工具栏。" },
    "workbench.showStatusBar":   { "type": "boolean", "default": true, "description": "Show the status bar.", "descriptionZh": "显示状态栏。" },
    "workbench.showExplorer":    { "type": "boolean", "default": true, "description": "Show the explorer panel.", "descriptionZh": "显示资源管理器。" },
    "workbench.sideBar.location": { "type": "string", "enum": ["left","right"], "default": "left", "description": "Side bar location.", "descriptionZh": "侧边栏位置。" },

    "terminal.fontFamily":       { "type": "string",  "default": "Consolas, Menlo, monospace", "description": "Terminal font family.", "descriptionZh": "终端字体族。" },
    "terminal.fontSize":         { "type": "integer", "default": 11, "minimum": 6, "maximum": 72, "description": "Terminal font size.", "descriptionZh": "终端字号。" },
    "terminal.shell.windows":    { "type": "string",  "default": "powershell.exe", "description": "Default Windows shell.", "descriptionZh": "Windows 默认 shell。" },
    "terminal.shell.linux":      { "type": "string",  "default": "/bin/bash", "description": "Default Linux shell.", "descriptionZh": "Linux 默认 shell。" },
    "terminal.shell.osx":        { "type": "string",  "default": "/bin/zsh", "description": "Default macOS shell.", "descriptionZh": "macOS 默认 shell。" },
    "terminal.cursorStyle":      { "type": "string",  "enum": ["block","line","underline"], "default": "block", "description": "Terminal cursor style.", "descriptionZh": "终端光标样式。" },

    "build.cmakePath":           { "type": "string",  "default": "cmake", "description": "CMake executable path.", "descriptionZh": "CMake 可执行文件路径。" },
    "build.generator":           { "type": "string",  "default": "Ninja", "description": "CMake generator.", "descriptionZh": "CMake 生成器。" },
    "build.parallelJobs":        { "type": "integer", "default": 0, "minimum": 0, "description": "Parallel job count (0 = auto).", "descriptionZh": "并行任务数（0 表示自动）。" },
    "build.configurations":      { "type": "array",   "items": { "type": "string" }, "default": ["Debug","Release"], "description": "Build configurations.", "descriptionZh": "构建配置列表。" },
    "build.defaultConfiguration":{ "type": "string",  "default": "Debug", "description": "Default build configuration.", "descriptionZh": "默认构建配置。" },

    "debug.gdbPath":             { "type": "string",  "default": "gdb", "description": "GDB path.", "descriptionZh": "GDB 路径。" },
    "debug.lldbPath":            { "type": "string",  "default": "lldb", "description": "LLDB path.", "descriptionZh": "LLDB 路径。" },
    "debug.breakOnException":    { "type": "boolean", "default": true, "description": "Break on uncaught exceptions.", "descriptionZh": "异常自动断点。" },
    "debug.showInlineValues":    { "type": "boolean", "default": true, "description": "Show inline variable values.", "descriptionZh": "在编辑器内联显示变量值。" },
    "debug.consoleEncoding":     { "type": "string",  "default": "UTF-8", "description": "Debug console text encoding.", "descriptionZh": "调试控制台编码。" },

    "git.path":                  { "type": "string",  "default": "git", "description": "git executable path.", "descriptionZh": "git 可执行文件路径。" },
    "git.autoFetch":             { "type": "boolean", "default": false, "description": "Periodically fetch from remote.", "descriptionZh": "定时从远端拉取。" },
    "git.autoFetchPeriod":       { "type": "integer", "default": 180, "minimum": 30, "description": "Auto fetch period (seconds).", "descriptionZh": "自动拉取周期（秒）。" },
    "git.confirmSync":           { "type": "boolean", "default": true, "description": "Confirm before syncing.", "descriptionZh": "同步前需要确认。" },
    "git.defaultBranch":         { "type": "string",  "default": "main", "description": "Default branch name.", "descriptionZh": "默认分支名。" },

    "plugins.enabled":           { "type": "boolean", "default": true, "description": "Master switch for plugins.", "descriptionZh": "插件总开关。" },
    "plugins.loadOrder":         { "type": "array",   "items": { "type": "string" }, "default": [], "description": "Explicit plugin load order.", "descriptionZh": "插件加载顺序。" },
    "plugins.sandboxTimeoutMs":  { "type": "integer", "default": 5000, "minimum": 100, "description": "Sandbox call timeout (ms).", "descriptionZh": "沙箱调用超时（毫秒）。" },
    "plugins.sandboxMemoryMb":   { "type": "integer", "default": 256, "minimum": 16, "description": "Sandbox memory cap (MB).", "descriptionZh": "沙箱内存上限（MB）。" },

    "topology.layoutAlgorithm":  { "type": "string",  "enum": ["hierarchical","force_directed","grid","circular","layered"], "default": "hierarchical", "description": "Graph layout algorithm.", "descriptionZh": "拓扑图布局算法。" },
    "topology.showPortLabels":   { "type": "boolean", "default": true, "description": "Show node port labels.", "descriptionZh": "显示节点端口标签。" },
    "topology.animateTransitions":{ "type":"boolean", "default": true, "description": "Animate layout transitions.", "descriptionZh": "动画过渡。" },
    "topology.drillDown.openInNewWindow": { "type": "boolean", "default": false, "description": "Drill-down opens in new window.", "descriptionZh": "下钻在新窗口打开。" },

    "polyc.path":                { "type": "string",  "default": "polyc", "description": "polyc executable path.", "descriptionZh": "polyc 可执行文件路径。" },
    "polyc.extraArgs":           { "type": "array",   "items": { "type": "string" }, "default": [], "description": "Extra polyc CLI arguments.", "descriptionZh": "polyc 额外命令行参数。" },
    "polyc.progressFormat":      { "type": "string",  "enum": ["ascii","json","none"], "default": "ascii", "description": "Progress reporter format.", "descriptionZh": "进度输出格式。" },
    "polyc.cacheEnabled":        { "type": "boolean", "default": true, "description": "Enable compilation cache.", "descriptionZh": "启用编译缓存。" },

    "frontend.tokenPool.arenaChunkBytes": { "type": "integer", "minimum": 4096, "maximum": 16777216, "default": 65536, "description": "Default StringArena chunk size used by the shared frontend token pool.", "descriptionZh": "前端共享 TokenPool 中 StringArena 的默认块大小（字节）。" },
    "frontend.tokenPool.shared":          { "type": "boolean", "default": true, "description": "Use the multi-threaded SharedTokenPool variant.", "descriptionZh": "启用多线程 SharedTokenPool 变体。" },
    "frontend.tokenPool.dumpStats":       { "type": "boolean", "default": false, "description": "Write <stem>.pool_stats.json after each compilation.", "descriptionZh": "每次编译后写出 <stem>.pool_stats.json 统计文件。" },

    "toolchains.cpp.default":    { "type": "string",  "default": "", "description": "Default C++ toolchain id.", "descriptionZh": "默认 C++ 工具链 id。" },
    "toolchains.python.default": { "type": "string",  "default": "", "description": "Default Python toolchain id.", "descriptionZh": "默认 Python 工具链 id。" },
    "toolchains.java.default":   { "type": "string",  "default": "", "description": "Default Java toolchain id.", "descriptionZh": "默认 Java 工具链 id。" },
    "toolchains.dotnet.default": { "type": "string",  "default": "", "description": "Default .NET toolchain id.", "descriptionZh": "默认 .NET 工具链 id。" },
    "toolchains.rust.default":   { "type": "string",  "default": "", "description": "Default Rust toolchain id.", "descriptionZh": "默认 Rust 工具链 id。" },
    "toolchains.go.default":     { "type": "string",  "default": "", "description": "Default Go toolchain id.", "descriptionZh": "默认 Go 工具链 id。" },
    "toolchains.js.default":     { "type": "string",  "default": "", "description": "Default JS toolchain id.", "descriptionZh": "默认 JS 工具链 id。" },
    "toolchains.ruby.default":   { "type": "string",  "default": "", "description": "Default Ruby toolchain id.", "descriptionZh": "默认 Ruby 工具链 id。" },

    "ploy.strictMode":           { "type": "boolean", "default": false, "description": "Enable polyc strict mode.", "descriptionZh": "启用严格模式。" },
    "ploy.packageDiscoveryEnabled": { "type": "boolean", "default": true, "description": "Enable package discovery.", "descriptionZh": "启用包发现。" },
    "ploy.langDirectiveAutoInfer": { "type": "boolean", "default": true, "description": "Auto-infer #lang directive.", "descriptionZh": "自动推断 #lang 指令。" },

    "files.associations":        { "type": "object",  "default": {}, "description": "Glob → language id map.", "descriptionZh": "文件名通配符到语言 id 的映射。" },
    "files.exclude":             { "type": "array",   "items": { "type": "string" }, "default": [], "description": "Glob patterns to exclude in explorer.", "descriptionZh": "资源管理器中排除的通配符。" },
    "files.encoding":            { "type": "string",  "default": "UTF-8", "description": "Default file encoding.", "descriptionZh": "默认文件编码。" },
    "files.eol":                 { "type": "string",  "enum": ["auto","\n","\r\n"], "default": "auto", "description": "Default end-of-line sequence.", "descriptionZh": "默认换行符。" }
  }
}
