{
  "editor.fontFamily": "Consolas, Menlo, monospace",
  "editor.fontSize": 11,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.wordWrap": false,
  "editor.minimap.enabled": false,
  "editor.lineNumbers": true,
  "editor.renderWhitespace": "selection",
  "editor.formatOnSave": false,
  "editor.autoSave": "off",
  "editor.autoSaveDelay": 1000,
  "editor.rulers": [],
  "editor.highlightCurrentLine": true,
  "editor.bracketMatching": true,
  "editor.autoIndent": true,

  "workbench.colorTheme": "Polyglot Dark",
  "workbench.iconTheme": "default",
  "workbench.startupEditor": "welcomePage",
  "workbench.showToolbar": true,
  "workbench.showStatusBar": true,
  "workbench.showExplorer": true,
  "workbench.sideBar.location": "left",

  "terminal.fontFamily": "Consolas, Menlo, monospace",
  "terminal.fontSize": 11,
  "terminal.shell.windows": "powershell.exe",
  "terminal.shell.linux": "/bin/bash",
  "terminal.shell.osx": "/bin/zsh",
  "terminal.cursorStyle": "block",

  "build.cmakePath": "cmake",
  "build.generator": "Ninja",
  "build.parallelJobs": 0,
  "build.configurations": ["Debug", "Release"],
  "build.defaultConfiguration": "Debug",

  "debug.gdbPath": "gdb",
  "debug.lldbPath": "lldb",
  "debug.breakOnException": true,
  "debug.showInlineValues": true,
  "debug.consoleEncoding": "UTF-8",

  "git.path": "git",
  "git.autoFetch": false,
  "git.autoFetchPeriod": 180,
  "git.confirmSync": true,
  "git.defaultBranch": "main",

  "plugins.enabled": true,
  "plugins.loadOrder": [],
  "plugins.sandboxTimeoutMs": 5000,
  "plugins.sandboxMemoryMb": 256,

  "topology.layoutAlgorithm": "hierarchical",
  "topology.showPortLabels": true,
  "topology.animateTransitions": true,
  "topology.drillDown.openInNewWindow": false,

  "polyc.path": "polyc",
  "polyc.extraArgs": [],
  "polyc.progressFormat": "ascii",
  "polyc.cacheEnabled": true,

  "frontend.tokenPool.arenaChunkBytes": 65536,
  "frontend.tokenPool.shared": true,
  "frontend.tokenPool.dumpStats": false,

  "toolchains.cpp.default": "",
  "toolchains.python.default": "",
  "toolchains.java.default": "",
  "toolchains.dotnet.default": "",
  "toolchains.rust.default": "",
  "toolchains.go.default": "",
  "toolchains.js.default": "",
  "toolchains.ruby.default": "",

  "ploy.strictMode": false,
  "ploy.packageDiscoveryEnabled": true,
  "ploy.langDirectiveAutoInfer": true,

  "keybindings.workbench.action.files.save": "Ctrl+S",
  "keybindings.workbench.action.files.saveAs": "Ctrl+Shift+S",
  "keybindings.workbench.action.files.openFile": "Ctrl+O",
  "keybindings.workbench.action.files.newUntitled": "Ctrl+N",
  "keybindings.workbench.action.closeActiveEditor": "Ctrl+W",
  "keybindings.workbench.action.quickOpen": "Ctrl+P",
  "keybindings.workbench.action.showCommands": "Ctrl+Shift+P",
  "keybindings.workbench.action.openSettings": "Ctrl+,",
  "keybindings.workbench.action.openSettingsJson": "Ctrl+K Ctrl+S",
  "keybindings.editor.action.toggleMarkdownPreview": "Ctrl+Shift+M",
  "keybindings.workbench.action.terminal.toggle": "Ctrl+`",
  "keybindings.workbench.action.debug.start": "F5",
  "keybindings.workbench.action.debug.continue": "F5",
  "keybindings.workbench.action.debug.stepOver": "F10",
  "keybindings.workbench.action.debug.stepInto": "F11",
  "keybindings.workbench.action.debug.stop": "Shift+F5",

  "files.associations": {
    "*.ploy": "ploy",
    "*.md": "markdown",
    "*.markdown": "markdown"
  },
  "files.exclude": [
    "**/build/**",
    "**/.git/**",
    "**/dependencies/**",
    "**/__pycache__/**",
    "**/*.pyc"
  ],
  "files.encoding": "UTF-8",
  "files.eol": "auto"
}
