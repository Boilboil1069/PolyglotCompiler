// ============================================================================
// database_access.ploy — Database access layer.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Python, Java.
// ============================================================================

// Database access: a Python connection wrapper hands rows to a Java DAO
// for typed mapping.  Demonstrates cross-language object handles via NEW +
// METHOD.

IMPORT python::db_connection;
IMPORT java::UserDao;

NEW conn = NEW(python, db_connection::Connection, "polyglot.db");
NEW dao  = NEW(java, UserDao);

LINK(python, java, db_connection::Connection::fetch_rows, UserDao::map_rows) {
    MAP_TYPE(python::list, java::java::util::List);
    MAP_TYPE(python::dict, java::java::util::Map);
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "22_database_access: ok\r\n";
