// =============================================================================
// Example 3: Multi-Language Data Processing Pipeline
// Demonstrates linking C++, Python, and Rust functions together
// =============================================================================

// Import modules from each language
IMPORT cpp::linalg;
IMPORT python::pandas;
IMPORT python::sklearn;
IMPORT rust::serde;

// Link C++ numeric computation
LINK(cpp, python, linalg::dot_product, pandas::dot);
LINK(cpp, python, linalg::normalize, pandas::norm);

// Link Python data processing
LINK(python, cpp, pandas::read_csv, io::read_file);
LINK(python, cpp, pandas::to_numpy, convert::to_array);
LINK(python, rust, sklearn::predict, ml::infer);

// Link Rust safe string handling
LINK(rust, python, serde::serialize, json::dumps);
LINK(rust, python, serde::deserialize, json::loads);

// Type mappings for cross-language interop
MAP_TYPE(cpp::double, python::float);
MAP_TYPE(cpp::double, rust::f64);
MAP_TYPE(python::float, rust::f64);
MAP_TYPE(cpp::char_ptr, python::str);
MAP_TYPE(cpp::char_ptr, rust::String);

// Data ingestion pipeline: Python reads data, C++ processes, Rust serializes
PIPELINE ml_inference {
    // Step 1: Load data via Python
    LET dataset = CALL(python, pandas::read_csv, "input.csv");
    LET raw_data = CALL(python, pandas::to_numpy, dataset);

    // Step 2: Normalize via C++
    LET size = 1024;
    CALL(cpp, linalg::normalize, raw_data, size);

    // Step 3: Run ML prediction via Python
    LET model_weights = CALL(python, pandas::read_csv, "weights.csv");
    LET model_data = CALL(python, pandas::to_numpy, model_weights);
    LET predictions = CALL(python, sklearn::predict, model_data, raw_data);

    // Step 4: Serialize results via Rust
    LET json_output = CALL(rust, serde::serialize, predictions);
    RETURN json_output;
}

// Helper function that computes similarity between two vectors
FUNC cosine_similarity(vec_a: ptr, vec_b: ptr, len: i32) -> f64 {
    LET dot = CALL(cpp, linalg::dot_product, vec_a, vec_b, len);

    // Compute magnitudes
    LET mag_a = CALL(cpp, linalg::dot_product, vec_a, vec_a, len);
    LET mag_b = CALL(cpp, linalg::dot_product, vec_b, vec_b, len);

    // Avoid division by zero
    IF mag_a < 0.000001 {
        RETURN 0.0;
    }
    IF mag_b < 0.000001 {
        RETURN 0.0;
    }

    // Return cosine similarity
    RETURN dot / (mag_a + mag_b);
}

EXPORT ml_inference AS "polyglot_ml_inference";
EXPORT cosine_similarity AS "polyglot_cosine_similarity";
