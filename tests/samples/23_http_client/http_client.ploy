// ============================================================================
// http_client.ploy — HTTP client demo.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Python, Go.
// ============================================================================

// HTTP client demo: a Go transport assembles the request line and a
// Python deserialiser turns the response body into a dict.

IMPORT go::HttpTransport;
IMPORT python::response_decoder;

LINK(go, python, HttpTransport::Get, response_decoder::decode) {
    MAP_TYPE(go::string, python::str);
    MAP_TYPE(go::int, python::int);
}

PIPELINE http_demo {
    STAGE go     CALL HttpTransport::Get;
    STAGE python CALL response_decoder::decode;
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "23_http_client: ok\r\n";
