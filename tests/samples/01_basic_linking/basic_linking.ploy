// ============================================================================
// basic_linking.ploy — Basic Cross-Language Linking Demo
//
// This .ploy file demonstrates the fundamental LINK/CALL/IMPORT/EXPORT
// directives that connect C++ and Python functions together.
//
// Source files:
//   - math_ops.cpp     (C++ math operations)
//   - string_utils.py  (Python string utilities)
//
// Compile:
//   polyc basic_linking.ploy -o basic_linking
// ============================================================================

// --- Module Imports ---
IMPORT cpp::math_ops;
IMPORT python::string_utils;

// --- Cross-Language Function Links ---
// Each LINK declaration connects two functions across language boundaries.
// MAP_TYPE entries define per-parameter ABI mappings between the target
// (first function) and the source (second function).  Both sides must have
// the same number of MAP_TYPE entries (one per parameter).

// Link C++ add(int,int) ↔ Python concat(str,str)  — both accept 2 params
LINK(cpp, python, math_ops::add, string_utils::concat) RETURNS cpp::int {
    MAP_TYPE(cpp::int, python::str);
    MAP_TYPE(cpp::int, python::str);
}

// Link C++ multiply(double,double) ↔ Python concat(str,str)
LINK(cpp, python, math_ops::multiply, string_utils::concat) RETURNS cpp::double {
    MAP_TYPE(cpp::double, python::str);
    MAP_TYPE(cpp::double, python::str);
}

// Link Python format_result(int) ↔ C++ abs_val(int) — both accept 1 param
LINK(python, cpp, string_utils::format_result, math_ops::abs_val) RETURNS python::str {
    MAP_TYPE(python::int, cpp::int);
}

// --- Global Type Mappings ---
MAP_TYPE(cpp::int, python::int);
MAP_TYPE(cpp::double, python::float);

// --- Polyglot Functions ---

// Compute a sum in C++ and format the result in Python
FUNC compute_and_format(a: INT, b: INT) -> STRING {
    LET sum = CALL(cpp, math_ops::add, a, b);
    LET product = CALL(cpp, math_ops::multiply, 3.14, 2.0);
    LET formatted = CALL(python, string_utils::format_result, sum);
    RETURN formatted;
}

// Export the polyglot functions
EXPORT compute_and_format AS "polyglot_compute";
