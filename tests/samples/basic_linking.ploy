// =============================================================================
// Example 1: Basic Cross-Language Linking
// Demonstrates LINK, FUNC, CALL, IMPORT, EXPORT, MAP_TYPE directives
// =============================================================================

// Import modules from different languages
IMPORT cpp::math;
IMPORT python::utils;

// Link C++ and Python functions using LINK(target, source, target_func, source_func)
LINK(cpp, python, math::add, utils::get_values);
LINK(cpp, python, math::multiply, utils::get_pair);

// Link a Python utility function to a Rust consumer
LINK(python, rust, utils::format_result, fmt::display);

// Define type mappings between C++ and Python numeric types
MAP_TYPE(cpp::int, python::int);
MAP_TYPE(cpp::double, python::float);

// A simple polyglot function that uses both C++ and Python
FUNC compute_and_format(a: i32, b: i32) -> str {
    LET sum = CALL(cpp, math::add, a, b);
    LET product = CALL(cpp, math::multiply, a, b);
    LET total = sum + product;
    LET formatted = CALL(python, utils::format_result, total);
    RETURN formatted;
}

// Export the polyglot function so it can be called from any language
EXPORT compute_and_format AS "polyglot_compute";
