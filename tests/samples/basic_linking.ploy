// =============================================================================
// Example 1: Basic Cross-Language Linking
// Demonstrates LINK, FUNC, and CALL directives
// =============================================================================

// Link external C++ math functions
LINK cpp::math::add AS FUNC(i32, i32) -> i32
LINK cpp::math::multiply AS FUNC(i32, i32) -> i32

// Link a Python utility function
LINK python::utils::format_result AS FUNC(i32) -> str

// Define a type mapping between C++ and Python numeric types
MAP_TYPE cpp::int -> python::int
MAP_TYPE cpp::double -> python::float

// A simple polyglot function that uses both C++ and Python
FUNC compute_and_format(a: i32, b: i32) -> str {
    LET sum = add(a, b)
    LET product = multiply(a, b)
    LET total = sum + product
    LET formatted = format_result(total)
    RETURN formatted
}

// Export the polyglot function so it can be called from any language
EXPORT compute_and_format AS "polyglot_compute"
