// ============================================================================
// Package Import Example
// Demonstrates IMPORT PACKAGE syntax for using language-native packages
// Includes version constraints, selective imports, and venv configuration
// ============================================================================

// Configure a virtual environment for Python package resolution
CONFIG VENV python "C:/Users/me/envs/data_science";

// Import Python packages with version constraints
IMPORT python PACKAGE numpy >= 1.20 AS np;
IMPORT python PACKAGE scipy.optimize >= 1.8 AS opt;
IMPORT python PACKAGE pandas >= 1.5.0;

// Selective imports: import only specific functions from a package
IMPORT python PACKAGE numpy::(array, mean, std);

// Combined: selective import with version constraint
IMPORT python PACKAGE torch::(tensor, no_grad) >= 2.0;

// Import a standard qualified module
IMPORT cpp::math;
IMPORT rust::serde;

// Import Rust crate with version constraint
IMPORT rust PACKAGE rayon >= 1.7;

// Link Python numpy functions to use from the pipeline
LINK(cpp, python, compute_mean, np::mean);
LINK(cpp, python, compute_std, np::std);
LINK(cpp, python, optimize, opt::minimize);

// Map numeric types between languages
MAP_TYPE(cpp::double, python::float);
MAP_TYPE(cpp::int, python::int);

// Pipeline: collect data, compute statistics, optimize
PIPELINE data_analysis {
    FUNC collect_data() -> LIST(f64) {
        LET data = [1.0, 2.5, 3.7, 4.2, 5.8, 6.1, 7.3];
        RETURN data;
    }

    FUNC statistics(data: LIST(f64)) -> TUPLE(f64, f64) {
        LET avg = CALL(python, np::mean, data);
        LET sd = CALL(python, np::std, data);
        RETURN (avg, sd);
    }

    FUNC run_optimization(initial: f64) -> f64 {
        LET result = CALL(python, opt::minimize, initial);
        RETURN result;
    }
}

// Export the pipeline entry point
EXPORT data_analysis AS "data_analysis_pipeline";
