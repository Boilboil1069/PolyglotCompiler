// ============================================================================
// Complex Type Examples — Demonstrates .ploy complex parameter type support
// ============================================================================

// --- Module imports ---

IMPORT cpp::graphics;
IMPORT python::numpy;
IMPORT rust::physics;

// --- STRUCT declarations ---

STRUCT Point {
    x: f64,
    y: f64
}

STRUCT Color {
    r: i32,
    g: i32,
    b: i32
}

STRUCT Particle {
    pos: f64,
    vel: f64,
    mass: f64
}

// --- LINK with complex parameter types ---

LINK(cpp, python, graphics::draw_point, numpy::make_point);
LINK(python, rust, numpy::dot_product, physics::vec_dot);
LINK(rust, cpp, physics::simulate, graphics::update);

// --- Type mappings ---

MAP_TYPE(cpp::double, python::float);
MAP_TYPE(rust::f64, cpp::double);

// --- Functions using struct literals ---

FUNC make_point(x: f64, y: f64) -> void {
    LET p = Point { x: x, y: y };
    RETURN;
}

FUNC make_color() -> void {
    LET blue = Color { r: 0, g: 0, b: 255 };
    LET red = Color { r: 255, g: 0, b: 0 };
    RETURN;
}

// --- Functions using list literals ---

FUNC make_list() -> void {
    LET numbers = [1, 2, 3, 4, 5];
    LET floats = [1.0, 2.5, 3.7];
    RETURN;
}

// --- Functions using CONVERT ---

FUNC convert_example(x: i32) -> void {
    LET y = CONVERT(x, f64);
    RETURN;
}

// --- MAP_FUNC declarations ---

MAP_FUNC point_to_list(p: ptr) -> ptr {
    RETURN 0;
}

MAP_FUNC list_to_vec(xs: ptr) -> ptr {
    RETURN 0;
}

// --- PIPELINE combining complex types ---

PIPELINE render_scene {
    LET origin = Point { x: 0.0, y: 0.0 };
    LET colors = [255, 128, 0];
    RETURN 0;
}
