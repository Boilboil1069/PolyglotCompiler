// ============================================================================
// string_processing.ploy — String processing pipeline.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Python, Rust.
// ============================================================================

// String processing pipeline blending a Rust tokenizer with a
// Python case-folder.  The .ploy file wires the two languages together via
// LINK + MAP_TYPE.

IMPORT rust::str_tokenizer;
IMPORT python::case_folder;

LINK(rust, python, str_tokenizer::tokenize, case_folder::fold) {
    MAP_TYPE(rust::String, python::str);
    MAP_TYPE(rust::Vec_String, python::list);
}

PIPELINE clean_text {
    STAGE rust  CALL str_tokenizer::tokenize;
    STAGE python CALL case_folder::fold;
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "17_string_processing: ok\r\n";
