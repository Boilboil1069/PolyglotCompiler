// ============================================================================
// event_loop.ploy — Event loop simulation.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Python, JavaScript.
// ============================================================================

// Event loop simulation: a JavaScript scheduler queues callbacks; a
// Python dispatcher drains the queue and reports a stable execution order.

IMPORT javascript::scheduler;
IMPORT python::dispatcher;

LINK(javascript, python, scheduler::schedule, dispatcher::drain) {
    MAP_TYPE(javascript::number, python::int);
    MAP_TYPE(javascript::string, python::str);
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "25_event_loop: ok\r\n";
