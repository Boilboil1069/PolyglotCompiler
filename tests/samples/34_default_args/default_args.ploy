// ============================================================================
// default_args.ploy — Named-parameter default values.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Ploy (host language only — no foreign tool-chains
// are required to build or run this sample).
//
// Demonstrates:
//   * declaring a FUNC with a trailing parameter that carries a constant
//     default value (`y: i32 = 0`);
//   * omitting that parameter at the call site (`add(1)`);
//   * naming the only required parameter (`add(x: 1)`);
//   * mixing a positional argument with a trailing named argument
//     (`add(1, y: 5)`);
//   * using a pure intra-Ploy call as a default value
//     (`scale(value: i32, factor: i32 = one())`).
// ============================================================================

FUNC one() -> i32 {
    RETURN 1;
}

FUNC add(x: i32, y: i32 = 0) -> i32 {
    RETURN x + y;
}

FUNC scale(value: i32, factor: i32 = one()) -> i32 {
    RETURN value * factor;
}

FUNC main() -> i32 {
    LET a = add(10);              // y defaults to 0  -> 10
    LET b = add(x: 7);            // y defaults to 0  -> 7
    LET c = add(2, y: 5);         // -> 7
    LET d = scale(value: 6);      // factor defaults to one() = 1 -> 6
    LET e = scale(4, 3);          // -> 12
    LET total = a + b + c + d + e;
    RETURN total;
}

PRINTLN "34_default_args: ok\r\n";
