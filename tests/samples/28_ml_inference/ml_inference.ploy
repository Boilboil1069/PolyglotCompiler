// ============================================================================
// ml_inference.ploy — ML inference pipeline.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Python, Rust.
// ============================================================================

// ML inference: a Python tokenizer feeds a Rust scoring kernel that
// returns a softmax probability over a small label set.

IMPORT python::tokenizer;
IMPORT rust::scorer;

LINK(python, rust, tokenizer::encode, scorer::score) {
    MAP_TYPE(python::list, rust::Vec_i64);
    MAP_TYPE(python::float, rust::f64);
}

PIPELINE infer {
    STAGE python CALL tokenizer::encode;
    STAGE rust   CALL scorer::score;
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "28_ml_inference: ok\r\n";
