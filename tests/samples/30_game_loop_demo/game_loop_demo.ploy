// ============================================================================
// game_loop_demo.ploy — Game loop skeleton.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: C++, Rust.
// ============================================================================

// Game loop skeleton: a C++ tick scheduler drives a Rust physics step at
// a fixed time-step.  The .ploy file links the two stages and asserts the
// integer tick budget is preserved across the boundary.

IMPORT cpp::tick_scheduler;
IMPORT rust::physics_step;

LINK(cpp, rust, tick_scheduler::next_tick, physics_step::advance) {
    MAP_TYPE(cpp::int, rust::u64);
    MAP_TYPE(cpp::double, rust::f64);
}

PIPELINE game_demo {
    STAGE cpp  CALL tick_scheduler::next_tick;
    STAGE rust CALL physics_step::advance;
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "30_game_loop_demo: ok\r\n";
