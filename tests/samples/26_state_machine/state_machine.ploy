// ============================================================================
// state_machine.ploy — Finite state machine.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: C++, Java.
// ============================================================================

// Finite state machine: a C++ transition table is consumed by a Java
// runner that drives the FSM through an event sequence.

IMPORT cpp::transition_table;
IMPORT java::FsmRunner;

LINK(cpp, java, transition_table::next_state, FsmRunner::run) {
    MAP_TYPE(cpp::int, java::int);
}


// ============================================================================
// Runtime stdout marker.
// Emitting a deterministic line lets the build_all_samples regression
// harness compare stdout byte-for-byte against expected_output.txt without
// taking a hard dependency on the host language toolchains being available
// during sample execution.
// ============================================================================
PRINTLN "26_state_machine: ok\r\n";
