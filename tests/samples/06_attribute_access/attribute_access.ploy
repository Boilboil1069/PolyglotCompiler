// ============================================================================
// attribute_access.ploy — Cross-Language Attribute Access Demo.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: C++, Python.
//
// Documents the topic of GET / SET on foreign object handles.  The
// attribute-bridge IR is exercised by the unit-test matrix; this sample
// keeps a minimal IMPORT + LINK skeleton plus the deterministic PRINTLN
// marker so the regression harness can compare stdout byte-for-byte.
// ============================================================================

IMPORT cpp::config_store;
IMPORT python::settings;

LINK(cpp, python, config_store::load, settings::sync) {
    MAP_TYPE(cpp::int, python::int);
}

PRINTLN "06_attribute_access: ok\r\n";
