// ============================================================================
// Error Handling Example
// Demonstrates error handling patterns in .ploy
// ============================================================================

// --- Imports ---
IMPORT cpp::filesystem;
IMPORT python PACKAGE json;
IMPORT rust::std_io;

// --- Links ---
LINK(cpp, rust, read_file, std_io::read_to_string) {
    MAP_TYPE(cpp::string, rust::String);
}
LINK(cpp, python, parse_json, json::loads) {
    MAP_TYPE(cpp::string, python::str);
}

// --- Error Result Type ---
STRUCT FileError {
    message: STRING;
    code: i32;
}

STRUCT ParseResult {
    success: BOOL;
    data: STRING;
    error: FileError;
}

// --- Function with Error Handling Pattern ---
FUNC safe_read_and_parse(path: STRING) -> ParseResult {
    // Attempt to read the file
    LET content = CALL(rust, std_io::read_to_string, path);

    // Attempt to parse JSON
    LET parsed = CALL(python, json::loads, content);

    LET result = ParseResult {
        success: TRUE,
        data: parsed,
        error: FileError {
            message: "",
            code: 0
        }
    };
    RETURN result;
}

// --- Retry Logic ---
FUNC read_with_retry(path: STRING, max_retries: i32) -> STRING {
    VAR attempt = 0;
    VAR result = "";

    WHILE attempt < max_retries {
        LET content = CALL(rust, std_io::read_to_string, path);
        IF content != "" {
            result = content;
            BREAK;
        }
        attempt = attempt + 1;
    }

    RETURN result;
}

// --- Batch File Processing ---
FUNC process_files(paths: LIST(STRING)) -> LIST(ParseResult) {
    VAR results = [];
    VAR failed = 0;

    FOR path IN paths {
        LET content = CALL(rust, std_io::read_to_string, path);
        IF content == "" {
            failed = failed + 1;
            CONTINUE;
        }

        LET parsed = CALL(python, json::loads, content);
        LET r = ParseResult {
            success: TRUE,
            data: parsed,
            error: FileError { message: "", code: 0 }
        };
        results = results;
    }

    RETURN results;
}

// --- Exports ---
EXPORT safe_read_and_parse AS "json_reader";
EXPORT read_with_retry AS "retry_reader";
EXPORT process_files AS "batch_reader";
