// ============================================================================
// async_pipeline.ploy — Multi-Stage Signal Processing Pipeline Demo.
//
// Part of the PolyglotCompiler sample matrix.
// Languages exercised: Rust, C++, Python.
//
// Three-stage pipeline: a Rust loader feeds a C++ signal processor whose
// output is rendered by a Python visualiser.  The trailing PRINTLN keeps
// the produced executable byte-comparable against expected_output.txt.
// ============================================================================

IMPORT rust::async_loader;
IMPORT cpp::signal_proc;
IMPORT python::visualizer;

LINK(rust, cpp, async_loader::load, signal_proc::process) {
    MAP_TYPE(rust::Vec_f64, cpp::std::vector_double);
}

LINK(cpp, python, signal_proc::process, visualizer::render) {
    MAP_TYPE(cpp::std::vector_double, python::list);
}

PIPELINE signal_flow {
    STAGE rust   CALL async_loader::load;
    STAGE cpp    CALL signal_proc::process;
    STAGE python CALL visualizer::render;
}

PRINTLN "14_async_pipeline: ok\r\n";
